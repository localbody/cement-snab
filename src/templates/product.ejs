          <span class="product__specification-title"
            >Наибольшая крупность заполнителя, не более мм</span
          >
          <span class="product__specification-subtitle">2,5</span>
        </div>
        <div class="product__specification">
          <span class="product__specification-title"
            >Количество воды затворения (на мешок 50 кг), л</span
          >
          <span class="product__specification-subtitle">6,5 - 8,0</span>
        </div>
      </div>
    </div>

    <div class="product__wrapper">
      <div class="panel product__to-card">
        <div class="product__purchase">
          <div class="product__price">
            <span class="product__price-summa">300,00</span
            ><sup class="product__asterix">*</sup>
          </div>
          <div class="in-stock">В наличии</div>
        </div>
        <div class="quantity">
          <button class="quantity__minus">-</button>
          <input class="quantity__input" type="number" value="0" />
          <button class="quantity__plus">+</button>
        </div>

        <div class="product__buttons">
          <button class="button button--accent">В корзину</button>
          <button class="button button--second">Купить в один клик</button>
        </div>

        <div class="product__asterix-info">
          <sup>*</sup>- Стоимость без учета
          <a class="product__delivery-link" href="">доставки</a>
        </div>
      </div>

      <!-- callback -->
      <%- include('../components/callback') %>
